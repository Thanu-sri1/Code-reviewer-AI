# Azure AI Foundry / Azure OpenAI settings.
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_DEPLOYMENT=gpt-4.1-mini
AZURE_OPENAI_API_VERSION=2025-01-01-preview

POSTGRES_DB=coderaptor
POSTGRES_USER=coderaptor
POSTGRES_PASSWORD=coderaptor


# Optional: only needed if you run the frontend outside Docker Compose.
# Docker Compose sets these automatically for the frontend container.
AUTH_SERVICE_URL=http://localhost:8001
EXECUTION_SERVICE_URL=http://localhost:8002
AI_SERVICE_URL=http://localhost:8003
REVIEW_SERVICE_URL=http://localhost:8004
